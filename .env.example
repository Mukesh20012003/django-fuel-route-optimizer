# ──────────────────────────────────────────────────────────────
# Fuel Route Optimizer – Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Django core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# External routing / geocoding API (OpenRouteService)
ROUTING_API_KEY=your-openrouteservice-api-key
ROUTING_API_BASE_URL=https://api.openrouteservice.org/v2/directions/driving-car

# PostgreSQL (set USE_POSTGRES=False to use SQLite instead)
USE_POSTGRES=True
POSTGRES_DB=fuel_route_db
POSTGRES_USER=fuel_route_user
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis cache (optional – falls back to in-memory LocMemCache if blank)
REDIS_URL=redis://127.0.0.1:6379/1

# CORS (set to False and use CORS_ALLOWED_ORIGINS in production)
CORS_ALLOW_ALL_ORIGINS=True
